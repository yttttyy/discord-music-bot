# Скопируй этот файл в .env и заполни значения

# Токен бота из https://discord.com/developers/applications
DISCORD_TOKEN=

# Префикс команд (по умолчанию !)
PREFIX=!

# Spotify ключи НЕ нужны — ссылки Spotify работают через публичный embed.

# --- YouTube cookies (нужны только для видео с возрастным ограничением 18+) ---
# Вариант 1: брать куки прямо из браузера, где ты залогинен в YouTube.
# Надёжнее всего firefox (chrome на Windows часто блокирует доступ к базе).
# На сервере/в Docker браузера нет — этот вариант работать НЕ будет.
YT_COOKIES_FROM_BROWSER=
# Вариант 2 (приоритетный; единственный рабочий на сервере): путь к
# экспортированному cookies.txt (расширение «Get cookies.txt LOCALLY»).
# В Docker: положи файл рядом с docker-compose.yml, раскомментируй volume
# и укажи YT_COOKIES_FILE=/app/cookies.txt
YT_COOKIES_FILE=
